# 线上服务器环境变量模板 —— 复制为 .env 后修改：cp .env.server.example .env
# 配合 compose.server.yml 使用（自包含：app + MariaDB + Redis）。

# 对外端口（宿主机 -> 容器 5409）
APP_PORT=5409
SERVER_PORT=5409

# 使用的镜像（一般不动；想固定版本可改成 :v1.0.2 或 :sha-xxxxxxx）
APP_IMAGE=ghcr.io/young-bo-i/canvasmind:latest

# ===== 数据库（MariaDB 密码与 DATABASE_URL 必须一致）=====
# ⚠️ 改成强密码
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_password
MYSQL_DATABASE=canana_mind
# 主机名 mariadb 是 compose 内的服务名，勿改
DATABASE_URL=mysql://root:CHANGE_ME_strong_password@mariadb:3306/canana_mind

# ===== 访问来源（CORS）=====
# 填你的访问地址，多个用逗号分隔。例：https://aigc.example.com
# 同 IP 临时测试可填：http://<服务器IP>:5409
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ===== 配置加密密钥（务必改成随机串）=====
# 生成：openssl rand -hex 32
PROVIDER_CONFIG_SECRET=CHANGE_ME_random_hex_32
STORAGE_CONFIG_SECRET=CHANGE_ME_random_hex_32

# 登录验证码 / 会话
AUTH_LOGIN_CODE_EXPIRE_MINUTES=5
AUTH_SESSION_EXPIRE_DAYS=30

# ===== Redis（compose 内置，无需改主机名）=====
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1
REDIS_PREFIX=canana
REDIS_ENV=production

# 说明：前端 VITE_API_BASE_URL 是"构建期"变量，已在镜像里固化为空=同源访问，
# 单域名部署无需在此设置；若前后端分域名，需在 CI 的仓库 Variables 配置后重新构建镜像。
