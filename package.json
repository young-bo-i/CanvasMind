{
  "name": "canvasmind",
  "private": true,
  "version": "1.0.2",
  "description": "AI-powered infinite canvas for image generation and creative collaboration",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently --kill-others \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "npm run prisma:generate && tsx watch --env-file=.env.development server/index.ts",
    "build": "npm run build:client",
    "preview": "vite preview",
    "start": "node scripts/start-production.mjs",
    "start:server": "node dist-service/server/index.js",
    "start:server:local": "tsx --env-file=.env.development server/index.ts",
    "storage:mkdir": "node -e \"require('node:fs').mkdirSync('uploads',{recursive:true})\"",
    "type-check": "vue-tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "build:client": "vue-tsc --noEmit && vite build",
    "build:service": "node scripts/build-server-service.mjs",
    "class-suffix:scan": "python3 scripts/class_suffix_cleanup.py --write-report",
    "class-suffix:apply": "python3 scripts/class_suffix_cleanup.py --apply --all --write-report",
    "docker:build": "docker build -t canana-vue:latest .",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.917.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "dotenv": "^17.4.2",
    "element-plus": "^2.13.1",
    "ioredis": "^5.10.1",
    "prisma": "^7.8.0",
    "vue": "^3.5.24",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.0.10",
    "@vitejs/plugin-vue": "^6.0.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.7",
    "tailwindcss": "^4.1.18",
    "terser": "^5.44.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^7.2.4",
    "vue-tsc": "^3.2.2"
  }
}
